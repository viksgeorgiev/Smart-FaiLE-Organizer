<Window x:Class="SmartFileOrganizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Smart File Organizer"
        Height="720"
        Width="1100"
        MinHeight="600"
        MinWidth="900"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="200" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="200" MinHeight="140" />
        </Grid.RowDefinitions>

        <!-- Top: folder selection -->
        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Source Folder"
                           Style="{StaticResource SectionHeaderStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />

                <TextBox Grid.Column="1"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding SelectedFolder, Mode=OneWay}"
                         IsReadOnly="True"
                         Margin="0,0,12,0" />

                <Button Grid.Column="2"
                        Content="Scan Folder"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ScanFolderCommand}"
                        Margin="0,0,8,0" />

                <Button Grid.Column="3"
                        Content="Select Folder"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SelectedFolderCommand}" />
            </Grid>
        </Border>

        <!-- Middle: rules (left) and preview (right) -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Organization Rules"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="Add Rule"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding AddRuleCommand}"
                                    Padding="12,6"
                                    Margin="0,0,8,0" />
                            <Button Content="Delete Rule"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DeleteRuleCommand}"
                                    Padding="12,6" />
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              Style="{StaticResource ModernDataGridStyle}"
                              ItemsSource="{Binding Rules}"
                              SelectedItem="{Binding SelectedRule}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Extension"
                                                Binding="{Binding Extension}"
                                                Width="120" />
                            <DataGridTextColumn Header="Destination Folder"
                                                Binding="{Binding DestinationFolder}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Files Preview"
                               Style="{StaticResource SectionHeaderStyle}" />

                    <DataGrid Grid.Row="1"
                              Style="{StaticResource ModernDataGridStyle}"
                              ItemsSource="{Binding Files}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File"
                                                Binding="{Binding FileName}"
                                                Width="140" />
                            <DataGridTextColumn Header="Source"
                                                Binding="{Binding SourcePath}"
                                                Width="*" />
                            <DataGridTextColumn Header="Destination Folder"
                                                Binding="{Binding DestinationFolder}"
                                                Width="120" />
                            <DataGridTextColumn Header="Destination"
                                                Binding="{Binding DestinationPath}"
                                                Width="*" />
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Organize button -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="Organize Files"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding OrganizeFilesCommand}"
                    Padding="24,10" />
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusTextStyle}"
                       Margin="16,0,0,0" />
        </StackPanel>

        <!-- Bottom: history -->
        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="History"
                           Style="{StaticResource SectionHeaderStyle}" />

                <DataGrid Grid.Row="1"
                          Style="{StaticResource ModernDataGridStyle}"
                          ItemsSource="{Binding History}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time"
                                            Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                            Width="150" />
                        <DataGridTextColumn Header="Source"
                                            Binding="{Binding SourcePath}"
                                            Width="*" />
                        <DataGridTextColumn Header="Destination"
                                            Binding="{Binding DestinationPath}"
                                            Width="*" />
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="90" />
                        <DataGridTextColumn Header="Message"
                                            Binding="{Binding Message}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
